/**
 * @file src_info.hpp
 * @brief This file defines some macro utils.
 *
 */
#pragma once


#define NNL_STR_HELPER(x) #x
#define NNL_STR(x) NNL_STR_HELPER(x)

#define NNL_GIT_HASH "@GIT_COMMIT_HASH@"

/**
 * @def NNL_FILE
 * @brief A macro that expands to the name of the source file.
 */
#ifndef NNL_FILE
#if defined(__FILE_NAME__)
#define NNL_FILE __FILE_NAME__
#else
#define NNL_FILE __FILE__
#endif
#endif

/**
 * @def NNL_SRCINF
 * @brief Source Information
 *
 * Expands to a std::string containing the function name, file name, and line number.
 */
#ifndef NNL_SRCINF
#include <string> // IWYU pragma: export
#define NNL_SRCINF (std::string(__func__) + "() at " NNL_FILE ":" NNL_STR(__LINE__))
#endif

#define NNL_SRCTAG(msg) ((msg) + (" [" + NNL_SRCINF + "]"))
